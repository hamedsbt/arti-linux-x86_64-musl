+    <script type="module">
+        import { TorClient, Log, storage } from './dist/entryPoints/wasm-base64/index.js';
+
+        // ── Constants ──────────────────────────────────────────────────────────
+        const MAX_LOG_ENTRIES = 500;       // max entries shown in DOM at once
+        const MAX_PERSISTED_LOGS = 10000;  // max entries kept in IndexedDB
+        const LOG_DB_NAME = 'tor-js-logs';
+        const LOG_STORE_NAME = 'logs';
+        const SESSION_ID = Date.now();     // unique identifier for this page load
+
+        // ── URL validation ─────────────────────────────────────────────────────
+        function validateUrl(url) {
+            if (!url || url.trim() === '') {
+                return { valid: false, error: 'URL cannot be empty' };
+            }
+            try {
+                const parsed = new URL(url);
+                if (!['https:', 'http:'].includes(parsed.protocol)) {
+                    return { valid: false, error: 'Only HTTP/HTTPS protocols are supported' };
+                }
+                const hostname = parsed.hostname;
+                if (hostname === 'localhost' ||
+                    hostname === '127.0.0.1' ||
+                    hostname.startsWith('192.168.') ||
+                    hostname.startsWith('10.') ||
+                    /^172\.(1[6-9]|2[0-9]|3[01])\./.test(hostname) ||
+                    hostname === '0.0.0.0') {
+                    return { valid: false, error: 'Private/local addresses are not allowed' };
+                }
+                return { valid: true, hostname };
+            } catch (e) {
+                return { valid: false, error: 'Invalid URL format' };
+            }
+        }
+
+        // ── Log entry DOM builder ──────────────────────────────────────────────
+        function createLogEntry(level, msg, isPrev = false) {
+            const entry = document.createElement('div');
+            entry.className = isPrev ? 'log-entry log-prev' : 'log-entry';
+
+            const levelSpan = document.createElement('span');
+            const levelUpper = level.toUpperCase();
+            const levelClasses = { INFO: 'log-info', ERROR: 'log-error', WARN: 'log-warn', DEBUG: 'log-debug' };
+            levelSpan.className = levelClasses[levelUpper] ?? 'log-debug';
+            levelSpan.textContent = levelUpper;
+            levelSpan.style.display = 'inline-block';
+            levelSpan.style.minWidth = '6ch';
+
+            const messageSpan = document.createElement('span');
+            messageSpan.textContent = msg;
+
+            entry.appendChild(levelSpan);
+            entry.appendChild(messageSpan);
+            return entry;
+        }
+
+        // ── Log persistence (IndexedDB) ────────────────────────────────────────
+        let _logDb = null;
+
+        async function getLogDb() {
+            if (_logDb) return _logDb;
+            _logDb = await new Promise((resolve, reject) => {
+                const req = indexedDB.open(LOG_DB_NAME, 1);
+                req.onerror = () => reject(req.error);
+                req.onsuccess = () => resolve(req.result);
+                req.onupgradeneeded = (e) => {
+                    const db = e.target.result;
+                    if (!db.objectStoreNames.contains(LOG_STORE_NAME)) {
+                        db.createObjectStore(LOG_STORE_NAME, { keyPath: 'id', autoIncrement: true });
+                    }
+                };
+            });
+            return _logDb;
+        }
+
+        async function persistLog(level, msg) {
+            try {
+                const db = await getLogDb();
+                await new Promise((resolve, reject) => {
+                    const tx = db.transaction(LOG_STORE_NAME, 'readwrite');
+                    const store = tx.objectStore(LOG_STORE_NAME);
+                    const addReq = store.add({ ts: Date.now(), level, msg, session: SESSION_ID });
+                    addReq.onsuccess = () => {
+                        // Prune entries that exceed the rolling window
+                        store.delete(IDBKeyRange.upperBound(addReq.result - MAX_PERSISTED_LOGS));
+                        tx.oncomplete = resolve;
+                    };
+                    addReq.onerror = () => reject(addReq.error);
+                    tx.onerror = () => reject(tx.error);
+                });
+            } catch (_) { /* best-effort: never let storage errors surface to UI */ }
+        }
+
+        async function getAllLogs() {
+            const db = await getLogDb();
+            return new Promise((resolve, reject) => {
+                const tx = db.transaction(LOG_STORE_NAME, 'readonly');
+                const req = tx.objectStore(LOG_STORE_NAME).getAll();
+                req.onsuccess = () => resolve(req.result);
+                req.onerror = () => reject(req.error);
+            });
+        }
+
+        // Render up to 200 previous-session entries below a separator.
+        async function loadPreviousLogs(output) {
+            try {
+                const allLogs = await getAllLogs();
+                const prev = allLogs.filter(e => e.session !== SESSION_ID);
+                if (prev.length === 0) return;
+
+                const emptyState = output.querySelector('.empty-state');
+                if (emptyState) emptyState.remove();
+
+                const sep = document.createElement('div');
+                sep.className = 'log-separator';
+                sep.textContent = `── ${prev.length} entries from previous sessions ──`;
+                output.appendChild(sep);
+
+                // Show the most recent 200, newest just below the separator
+                const toShow = prev.slice(-200);
+                for (let i = toShow.length - 1; i >= 0; i--) {
+                    output.appendChild(createLogEntry(toShow[i].level, toShow[i].msg, true));
+                }
+            } catch (_) { /* best-effort */ }
+        }
+
+        // ── Minimal ZIP builder (store/no-compression method) ─────────────────
+        function buildZip(files) {
+            // Build CRC-32 lookup table (standard polynomial 0xEDB88320)
+            const crc32Table = new Uint32Array(256);
+            for (let n = 0; n < 256; n++) {
+                let c = n;
+                for (let k = 0; k < 8; k++) c = c & 1 ? 0xEDB88320 ^ (c >>> 1) : c >>> 1;
+                crc32Table[n] = c;
+            }
+            function crc32(buf) {
+                let c = 0xFFFFFFFF;
+                for (const b of buf) c = (c >>> 8) ^ crc32Table[(c ^ b) & 0xFF];
+                return (c ^ 0xFFFFFFFF) >>> 0;
+            }
+
+            const enc = new TextEncoder();
+            const localParts = [];
+            const cdParts = [];
+            let localOffset = 0;
+
+            for (const { name, data } of files) {
+                const nameBytes = enc.encode(name);
+                const crc = crc32(data);
+                const size = data.length;
+
+                // Local file header (30 bytes fixed + filename)
+                const lh = new Uint8Array(30 + nameBytes.length);
+                const lv = new DataView(lh.buffer);
+                lv.setUint32(0, 0x04034b50, true);        // local file header signature
+                lv.setUint16(4, 20, true);                 // version needed to extract (2.0)
+                lv.setUint32(14, crc, true);               // CRC-32
+                lv.setUint32(18, size, true);              // compressed size (= uncompressed, stored)
+                lv.setUint32(22, size, true);              // uncompressed size
+                lv.setUint16(26, nameBytes.length, true);  // filename length
+                lh.set(nameBytes, 30);
+
+                // Central directory header (46 bytes fixed + filename)
+                const cd = new Uint8Array(46 + nameBytes.length);
+                const cv = new DataView(cd.buffer);
+                cv.setUint32(0, 0x02014b50, true);         // central directory signature
+                cv.setUint16(4, 20, true);                 // version made by
+                cv.setUint16(6, 20, true);                 // version needed
+                cv.setUint32(16, crc, true);               // CRC-32
+                cv.setUint32(20, size, true);              // compressed size
+                cv.setUint32(24, size, true);              // uncompressed size
+                cv.setUint16(28, nameBytes.length, true);  // filename length
+                cv.setUint32(42, localOffset, true);       // offset of local file header
+                cd.set(nameBytes, 46);
+
+                localParts.push(lh, data);
+                cdParts.push(cd);
+                localOffset += lh.length + size;
+            }
+
+            // End of central directory record
+            const cdSize = cdParts.reduce((s, p) => s + p.length, 0);
+            const eocd = new Uint8Array(22);
+            const ev = new DataView(eocd.buffer);
+            ev.setUint32(0, 0x06054b50, true);   // end of central directory signature
+            ev.setUint16(8, files.length, true);  // number of entries on this disk
+            ev.setUint16(10, files.length, true); // total number of entries
+            ev.setUint32(12, cdSize, true);        // size of central directory
+            ev.setUint32(16, localOffset, true);   // offset of central directory
+
+            return new Blob([...localParts, ...cdParts, eocd], { type: 'application/zip' });
+        }
+
+        // ── Minimal ZIP reader (store/no-compression only) ──────────────────────
+        function readZip(arrayBuffer) {
+            const view = new DataView(arrayBuffer);
+            const dec = new TextDecoder();
+            const files = {};
+            let offset = 0;
+
+            while (offset + 30 <= arrayBuffer.byteLength) {
+                if (view.getUint32(offset, true) !== 0x04034b50) break;
+                const nameLen = view.getUint16(offset + 26, true);
+                const extraLen = view.getUint16(offset + 28, true);
+                const compSize = view.getUint32(offset + 18, true);
+                const name = dec.decode(new Uint8Array(arrayBuffer, offset + 30, nameLen));
+                const dataStart = offset + 30 + nameLen + extraLen;
+                files[name] = new Uint8Array(arrayBuffer, dataStart, compSize);
+                offset = dataStart + compSize;
+            }
+
+            return files;
+        }
+
+        // ── Log instance ───────────────────────────────────────────────────────
+        const log = new Log({
+            rawLog: (level, ...args) => {
+                const output = document.getElementById('logOutput');
+                if (!output) return;
+
+                const emptyState = output.querySelector('.empty-state');
+                if (emptyState) emptyState.remove();
+
+                // Keep DOM bounded; oldest entries (at the bottom) are dropped first
+                while (output.children.length >= MAX_LOG_ENTRIES) {
+                    output.removeChild(output.lastChild);
+                }
+
+                const msg = args.join(' ');
+                persistLog(level, msg);
+                output.insertBefore(createLogEntry(level, msg), output.firstChild);
+            },
+        });
+
+        // ── Global error handlers ──────────────────────────────────────────────
+        window.addEventListener('error', (event) => {
+            console.error('Uncaught error:', event.error);
+            log.error('Uncaught error: ' + (event.error?.message || 'Unknown error'));
+        });
+
+        window.addEventListener('unhandledrejection', (event) => {
+            console.error('Unhandled promise rejection:', event.reason);
+            log.error('Unhandled rejection: ' + (event.reason?.message || event.reason || 'Unknown error'));
+        });
+
+        async function run() {
+            const statusEl = document.getElementById('status');
+            const statusDot = document.getElementById('statusDot');
+            const gatewayUrlInput = document.getElementById('gatewayUrl');
+            const connectBtn = document.getElementById('connectBtn');
+            const closeBtn = document.getElementById('closeBtn');
+            const fetchBtn = document.getElementById('fetchBtn');
+            const presetSelect = document.getElementById('presetSelect');
+            const urlInput = document.getElementById('urlInput');
+            const fetchOutput = document.getElementById('fetchOutput');
+            const clearBtn = document.getElementById('clearBtn');
+            const logLevelSelect = document.getElementById('logLevel');
+            const logOutput = document.getElementById('logOutput');
+            const deleteStateBtn = document.getElementById('deleteStateBtn');
+            const downloadDebugBtn = document.getElementById('downloadDebugBtn');
+            const loadStateBtn = document.getElementById('loadStateBtn');
+            const loadStateFile = document.getElementById('loadStateFile');
+            const debugOutput = document.getElementById('debugOutput');
+
+            // Preset selection handler
+            presetSelect.addEventListener('change', () => {
+                const value = presetSelect.value;
+                if (value !== 'custom') {
+                    urlInput.value = value;
+                }
+            });
+
+            // Clear logs (DOM only; persisted history is preserved for download)
+            clearBtn.addEventListener('click', () => {
+                logOutput.innerHTML = '<div class="empty-state">Logs cleared.</div>';
+            });
+
+            // Update log level on the active TorClient
+            logLevelSelect.addEventListener('change', () => {
+                if (torClient) {
+                    torClient.setLogLevel(logLevelSelect.value);
+                    log.info(`Log level changed to ${logLevelSelect.value}`);
+                }
+            });
+
+            // Debug: delete state except microdescs
+            deleteStateBtn.addEventListener('click', async () => {
+                deleteStateBtn.disabled = true;
+                debugOutput.className = 'output-box loading';
+                debugOutput.textContent = 'Deleting...';
+                try {
+                    const dbName = 'tor-js';
+                    const db = await new Promise((resolve, reject) => {
+                        const req = indexedDB.open(dbName, 1);
+                        req.onerror = () => reject(req.error);
+                        req.onsuccess = () => resolve(req.result);
+                        req.onupgradeneeded = (e) => {
+                            const db = e.target.result;
+                            if (!db.objectStoreNames.contains('keyvalue')) {
+                                db.createObjectStore('keyvalue');
+                            }
+                        };
+                    });
+
+                    const tx = db.transaction('keyvalue', 'readwrite');
+                    const store = tx.objectStore('keyvalue');
+                    const allKeys = await new Promise((resolve, reject) => {
+                        const req = store.getAllKeys();
+                        req.onerror = () => reject(req.error);
+                        req.onsuccess = () => resolve(req.result);
+                    });
+
+                    const toDelete = allKeys.filter(k => !String(k).startsWith('dir:microdesc:'));
+                    for (const key of toDelete) {
+                        store.delete(key);
+                    }
+
+                    await new Promise((resolve, reject) => {
+                        tx.oncomplete = () => resolve();
+                        tx.onerror = () => reject(tx.error);
+                    });
+
+                    const kept = allKeys.length - toDelete.length;
+                    debugOutput.className = 'output-box success';
+                    debugOutput.textContent = `Deleted ${toDelete.length} keys, kept ${kept} microdesc keys`;
+                    log.info(`Debug: deleted ${toDelete.length} state keys (kept ${kept} microdescs)`);
+                } catch (e) {
+                    debugOutput.className = 'output-box error';
+                    debugOutput.textContent = e.message || String(e);
+                    log.error('Debug: delete state failed: ' + (e.message || e));
+                }
+                deleteStateBtn.disabled = false;
+            });
+
+            // Debug: download zip of all persisted logs + current Tor state
+            downloadDebugBtn.addEventListener('click', async () => {
+                downloadDebugBtn.disabled = true;
+                debugOutput.className = 'output-box loading';
+                debugOutput.textContent = 'Building zip...';
+                try {
+                    const enc = new TextEncoder();
+
+                    // Collect all persisted log entries
+                    const logs = await getAllLogs();
+                    const logLines = logs.map(e => {
+                        const dt = new Date(e.ts).toISOString();
+                        const mark = e.session === SESSION_ID ? 'current' : 'prev';
+                        return `[${dt}] [${mark}] ${e.level.toUpperCase()}: ${e.msg}`;
+                    }).join('\n');
+
+                    // Collect all key-value pairs from the Tor state DB
+                    const stateDb = await new Promise((resolve, reject) => {
+                        const req = indexedDB.open('tor-js', 1);
+                        req.onerror = () => reject(req.error);
+                        req.onsuccess = () => resolve(req.result);
+                        req.onupgradeneeded = (e) => {
+                            const db = e.target.result;
+                            if (!db.objectStoreNames.contains('keyvalue')) {
+                                db.createObjectStore('keyvalue');
+                            }
+                        };
+                    });
+                    const stateEntries = await new Promise((resolve, reject) => {
+                        const tx = stateDb.transaction('keyvalue', 'readonly');
+                        const store = tx.objectStore('keyvalue');
+                        const keysReq = store.getAllKeys();
+                        keysReq.onsuccess = () => {
+                            const valsReq = store.getAll();
+                            valsReq.onsuccess = () => {
+                                const obj = {};
+                                keysReq.result.forEach((k, i) => { obj[k] = valsReq.result[i]; });
+                                resolve(obj);
+                            };
+                            valsReq.onerror = () => reject(valsReq.error);
+                        };
+                        keysReq.onerror = () => reject(keysReq.error);
+                    });
+                    const stateJson = JSON.stringify({
+                        version: 1,
+                        captured_at: new Date().toISOString(),
+                        entries: stateEntries,
+                    }, null, 2);
+
+                    const zipBlob = buildZip([
+                        { name: 'logs.txt',   data: enc.encode(logLines) },
+                        { name: 'state.json', data: enc.encode(stateJson) },
+                    ]);
+
+                    const url = URL.createObjectURL(zipBlob);
+                    const a = document.createElement('a');
+                    a.href = url;
+                    a.download = `tor-js-debug-${new Date().toISOString().replace(/[:.]/g, '-')}.zip`;
+                    a.click();
+                    URL.revokeObjectURL(url);
+
+                    const nState = Object.keys(stateEntries).length;
+                    debugOutput.className = 'output-box success';
+                    debugOutput.textContent = `Downloaded: ${logs.length} log entries, ${nState} state keys`;
+                    log.info(`Debug: downloaded zip (${logs.length} logs, ${nState} state keys)`);
+                } catch (e) {
+                    debugOutput.className = 'output-box error';
+                    debugOutput.textContent = e.message || String(e);
+                    log.error('Debug: download zip failed: ' + (e.message || e));
+                }
+                downloadDebugBtn.disabled = false;
+            });
+
+            // Debug: load state from a previously downloaded debug zip
+            loadStateBtn.addEventListener('click', () => {
+                loadStateFile.value = '';
+                loadStateFile.click();
+            });
+
+            loadStateFile.addEventListener('change', async () => {
+                const file = loadStateFile.files[0];
+                if (!file) return;
+
+                loadStateBtn.disabled = true;
+                debugOutput.className = 'output-box loading';
+                debugOutput.textContent = 'Reading zip...';
+                try {
+                    const buf = await file.arrayBuffer();
+                    const files = readZip(buf);
+
+                    if (!files['state.json']) {
+                        throw new Error('No state.json found in zip');
+                    }
+
+                    const stateJson = JSON.parse(new TextDecoder().decode(files['state.json']));
+                    const entries = stateJson.entries;
+                    if (!entries || typeof entries !== 'object') {
+                        throw new Error('Invalid state.json: missing entries object');
+                    }
+
+                    const dbName = 'tor-js';
+                    const db = await new Promise((resolve, reject) => {
+                        const req = indexedDB.open(dbName, 1);
+                        req.onerror = () => reject(req.error);
+                        req.onsuccess = () => resolve(req.result);
+                        req.onupgradeneeded = (e) => {
+                            const db = e.target.result;
+                            if (!db.objectStoreNames.contains('keyvalue')) {
+                                db.createObjectStore('keyvalue');
+                            }
+                        };
+                    });
+
+                    const keys = Object.keys(entries);
+                    const tx = db.transaction('keyvalue', 'readwrite');
+                    const store = tx.objectStore('keyvalue');
+                    for (const key of keys) {
+                        store.put(entries[key], key);
+                    }
+
+                    await new Promise((resolve, reject) => {
+                        tx.oncomplete = () => resolve();
+                        tx.onerror = () => reject(tx.error);
+                    });
+
+                    debugOutput.className = 'output-box success';
+                    debugOutput.textContent = `Loaded ${keys.length} state keys from ${file.name} (captured ${stateJson.captured_at || 'unknown'})`;
+                    log.info(`Debug: loaded ${keys.length} state keys from ${file.name}`);
+                } catch (e) {
+                    debugOutput.className = 'output-box error';
+                    debugOutput.textContent = e.message || String(e);
+                    log.error('Debug: load state failed: ' + (e.message || e));
+                }
+                loadStateBtn.disabled = false;
+            });
+
+            // Load previous session logs before showing "Ready"
+            await loadPreviousLogs(logOutput);
+
+            let torClient = null;
+
+            statusEl.textContent = 'Ready to connect';
+            statusDot.className = 'status-dot';
+            log.info('Ready - click "Connect" to start');
+
+            connectBtn.addEventListener('click', async () => {
+                const gateway = gatewayUrlInput.value.trim();
+                if (!gateway) {
+                    log.error('Gateway URL is required');
+                    return;
+                }
+
+                connectBtn.disabled = true;
+                statusEl.textContent = 'Connecting...';
+                statusDot.className = 'status-dot loading';
+                log.info(`Connecting via gateway: ${gateway}...`);
+
+                try {
+                    const startTime = performance.now();
+                    torClient = new TorClient({
+                        gateway,
+                        log,
+                        logLevel: logLevelSelect.value,
+                    });
+                    await torClient.ready();
+
+                    const connectTime = ((performance.now() - startTime) / 1000).toFixed(1);
+                    statusEl.textContent = `Connected (${connectTime}s)`;
+                    statusDot.className = 'status-dot ready';
+                    log.info(`Connected in ${connectTime}s`);
+
+                    closeBtn.disabled = false;
+                    fetchBtn.disabled = false;
+
+                } catch (e) {
+                    statusEl.textContent = 'Connection failed';
+                    statusDot.className = 'status-dot error';
+                    log.error('Connection failed: ' + (e.message || e));
+                    connectBtn.disabled = false;
+                }
+            });
+
+            closeBtn.addEventListener('click', () => {
+                if (torClient) {
+                    torClient.close();
+                    log.info('Disconnected');
+                    torClient = null;
+                }
+                statusEl.textContent = 'Disconnected';
+                statusDot.className = 'status-dot';
+                connectBtn.disabled = false;
+                closeBtn.disabled = true;
+                fetchBtn.disabled = true;
+            });
+
+            fetchBtn.addEventListener('click', async () => {
+                const url = urlInput.value;
+
+                const validation = validateUrl(url);
+                if (!validation.valid) {
+                    fetchOutput.className = 'output-box error';
+                    fetchOutput.textContent = validation.error;
+                    return;
+                }
+
+                fetchOutput.className = 'output-box loading';
+                fetchOutput.textContent = 'Fetching...';
+                fetchBtn.disabled = true;
+                log.info(`Fetching ${url}...`);
+
+                try {
+                    const startTime = performance.now();
+                    const response = await torClient.fetch(url);
+                    const fetchTime = ((performance.now() - startTime) / 1000).toFixed(1);
+
+                    const text = await response.text();
+                    fetchOutput.className = 'output-box success';
+                    fetchOutput.textContent = `Status: ${response.status} (${fetchTime}s)\n\n${text.substring(0, 2000)}`;
+                    log.info(`Fetch complete: ${response.status} (${fetchTime}s, ${text.length} bytes)`);
+                } catch (e) {
+                    fetchOutput.className = 'output-box error';
+                    fetchOutput.textContent = e.message || String(e);
+                    log.error('Fetch failed: ' + (e.message || e));
+                }
+                fetchBtn.disabled = false;
+            });
+        }
+
+        // ── Main-thread sync checker ──────────────────────────────────────
+        // Reports when the main thread is blocked for >500ms.
+        {
+            let last = performance.now();
+            setInterval(() => {
+                const now = performance.now();
+                const dt = now - last;
+                last = now;
+                if (dt > 500) {
+                    log.warn(`[sync-check] Main thread blocked for ${dt.toFixed(0)}ms`);
+                }
+            }, 100);
+        }
+
+        if (document.readyState === 'loading') {
+            document.addEventListener('DOMContentLoaded', run);
+        } else {
+            run();
+        }
+    </script>
+</body>
+</html>
